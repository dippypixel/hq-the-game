trigger1 = Time = 0
attr = A, NA
damage    = 20
guardflag = HA
priority = 3
pausetime = 7,7
sparkno = 1
sparkxy = -10,-70
hitsound   = 5,0
guardsound = 6,0
ground.type = High
ground.slidetime = 7
ground.hittime  = 8
ground.velocity = (vel x*-1)
air.velocity = (vel x*-1),ifelse(vel y > -2,-2,(vel y))
air.hittime = 14
mindist = 20,-20
maxdist = 60,80
air.hittime = 15                 ;Time before opponent regains control in air
envshake.time = 3
envshake.freq =60
envshake.ampl = -1
envshake.phase =90
[State 0, VelSet]
type = velset
trigger1 = !time && prevstateno = 600 && vel y > -2 ;&& pos y > -80
y = -2

[State 600, 3]
type = CtrlSet
trigger1 = Time = 17
value = 1

