physics = S
anim = 105
sprpriority = 1
[State 210, 1]
type = PlaySnd
trigger1 = Time = 1
value = 1000, 0

[State 100, 1]
type = Velset
trigger1 = 1
x = -17

[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
