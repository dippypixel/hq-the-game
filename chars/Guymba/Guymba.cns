;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1
facep2 = 1

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1) = 0, const(velocity.jump.neu.x), ifelse(sysvar(1) = 1, ifelse(prevstateno = 100, const(velocity.runjump.fwd.x), const(velocity.jump.fwd.x)),ifelse(prevstateno = 105, const(velocity.runjump.back.x), const(velocity.jump.back.x)))*ifelse(command="holdup", 1, 1.334))
y = ifelse(command!="holdup",const(velocity.jump.y)*0.667,const(velocity.jump.y))

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1



;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > Const720p(-8)
trigger1 = SelfAnimExist(anim + 3)
trigger1 = anim >= 41 && anim <= 43
persistent = 0
value = Anim + 3

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -50
;ignorehitpause = 
;persistent = 

[State 0, VelAdd]
type = Veladd
trigger1 = command = "holdfwd" && prevstateno=9000 && vel x < 5
x = .5
[State 0, VelAdd]
type = Veladd
trigger1 = command = "holdback" && prevstateno=9000  && vel x > -5
x = -.5

;---------------------------------------------------------------------------
; SuperJump Start
[Statedef 9000]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1
facep2 = 1

[State 3400,AfterImage]
type = AfterImage
trigger1 = !time
time = 20
TimeGap  = 1
FrameGap = 4
length = 15
PalBright   = 0,0,0
PalContrast = 255,255,255
PalMul      = .8,.8,.8

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = f41,0
freqmul = 1
volumescale = 200
freqmul = 0.9+(random/5333.3)


[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1


[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
y = ifelse(command="holdup",const(velocity.jump.y)*2.2,const(velocity.jump.y)*2)
[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=0
x = 0
[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=-1
x = -5
[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=1
x = 5

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1




[Statedef -3]

[State -3, High Speed Width]
type = width
trigger1 = vel x > 0
player = (vel x), ifelse(vel x<0,0,(vel x))
ignorehitpause = 1
[State 0, Mapset]
type = MapSet
trigger1 = !numtarget
map = "movement_ability_used"
value = 0
ignorehitpause = 1
[State 0, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = 1
text = "var(10) = %f"
params = ifelse((p2bodydist x/600)<1,1,ifelse(p2bodydist x/600>2,2,p2bodydist x/600))
;ignorehitpause = 
;persistent = 
;ignorehitpause = 
;persistent = 
[State -3, stagrevear]
type = null;ModifyStageVar
trigger1 = enemy,stateno = 5800 && enemy,time = 1
camera.zoomout = camerazoom
ignorehitpause =1
[State -3, stagrevear]
type = null;ModifyStageVar
trigger1 = enemy,stateno = 5820 && stagevar(camera.zoomout)
camera.zoomout= .1
ignorehitpause =1
;This controller plays a sound everytime KFM lands from a jump, or
;from his back-dash.

[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 40, 0
