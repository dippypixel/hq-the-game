;---------------------------------------------------------------------------
; Run forward
[Statedef 100]
type    = S
physics = S
anim = 100
sprpriority = 1
[State 210, 1]
type = PlaySnd
trigger1 = Time = 1
value = 1000, 0

[State 100, 1]
type = Velset
trigger1 = 1
x = 17*ifelse((p2bodydist x/600)<1,1,ifelse(p2bodydist x/600>2,2,p2bodydist x/600))

[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn
flag2= NoBrake



[State 100, 4]
type = ChangeState
trigger1 = time > 20
value = 0

