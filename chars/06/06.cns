value = 9000
ctrl = 1
[State 0, ChangeState]
type = ChangeState
trigger1 = AnimTime = 0 
value = 0
ctrl = 1

;---------------------------------------------------------------------------
;Counter
[Statedef 300]
type    = U
movetype= A
physics = N
juggle  = 0
poweradd= 0
anim = 300
ctrl = 0
sprpriority = 2
[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = time = 1 
trigger1 = pos y != 0
statetype = A
[State 0, StateTypeSet]
type = StateTypeSet
trigger1 = time = 1
trigger1 = pos y >= -1
statetype = S

[State 0, PosSet]
type = PosSet
trigger1= vel y > 0
trigger1= pos y > -vel y
y = 0
[State 0, VelSet]
type = VelSet
trigger1= vel y > 0
trigger1= pos y > -vel y
y = 0

[State 0, Gravity]
type = Veladd
trigger1 = statetype = A 
y = const(movement.yaccel)
[State 610, 2]
type = PlaySnd
trigger1 = Time = 2
value = S0, 3
freqmul = 0.96+(random/7333.0)
[State 0, ReversalDef]
type = ReversalDef
trigger1 = animelem = 2
reversal.attr = SA,NA,SA,HA,NT,ST           ;SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
pausetime = 12,12
hitsound = 5,0
p1stateno = 301



[State 0, NotHitBy]
type = NotHitBy
trigger1 = time = 2 
value = SCA,NA,SA,HA,NP,SP,NT,ST
;value2 = S,NA
time = 3


[State 200, 3]
type = ChangeState
trigger1 = AnimTime = 0
value = ifelse(statetype=A,50,0)
ctrl = 1


