type = PlaySnd
trigger1 = !TIME
value = f41,0
freqmul = 1
volumescale = 200
freqmul = 0.9+(random/5333.3)

[State 100, 1]
type = Velset
trigger1 =!time
x = -20

[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn
flag2= NoBrake

[State 100, 4]
type = ChangeState
trigger1 = command = "holdback" && time > 10
value = 106

[State 100, 4]
type = ChangeState
trigger1 = time > 20
value = 0
;---------------------------------------------------------------------------
; Run Back
[Statedef 106]
type    = S
physics = N
sprpriority = 1

[State 100, 1]
type = Velset
trigger1 = !time
x = -const(velocity.run.fwd.x)*.5
[State 100, 1]
type = Veladd
trigger1 = vel x >= -30 
x = -.2

[State 106, EnvShake]
type = EnvShake
trigger1 = animelemtime(1)=0 
trigger2 = animelemtime(4)=0
time = 1
freq = 60
ampl = -4

[State 0, VarSet]
type = Varadd
trigger1 = time%(ifelse(abs(30/vel x*2)<2,2,abs(30/vel x*2)))=0
v = 10    ;fv = 10
value = 1
[State 0, VarSet]
type = Varset
trigger1 = var(10) >6
v = 10    ;fv = 10
value = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = Animelemno(0) != var(10)
value = 106
elem = var(10)


[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn
flag= NoBrake

[State 0, EnvShake]
type = EnvShake
trigger1 = animelemtime(1)=1
trigger2 = animelemtime(4)=1
time = 5
freq = 60
ampl = -1*(camerazoom*2.2)
phase = 90

[State -3, Landing Sound]
type = PlaySnd
trigger1 = animelemtime(1)=0 
trigger2 = animelemtime(4)=0
value = 100, 0+random%4
freqmul = 0.9+(random/5333.0)

[State 100, 4]
type = ChangeState
trigger1 = command != "holdback" 
value = 101


;---------------------
;LITERALLY just to fix that one bug that drives me NUTS where in order to turn you have to do like some frame perfect shit
; RunEnd
[Statedef 101]
type = S
physics = S
sprpriority = 0
ctrl = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 20, 2]
type = ChangeState
trigger1 = !ailevel
trigger1 = command = "holdback"
trigger1 = (prevstateno = 100) 
value = 105


[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = time > 6
value = 0


;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1
facep2 = 1
[State 40, 1]
type = ChangeState
trigger1 = command = "SuperJump2"
value = 9000
ctrl = 0

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1) = 0, const(velocity.jump.neu.x), ifelse(sysvar(1) = 1, ifelse(prevstateno = 100, (vel x)*1.2, const(velocity.jump.fwd.x)),ifelse(prevstateno = [105,106], (vel x)*1.2, const(velocity.jump.back.x)))*ifelse(command="holdup", 1, 1.334))
y = ifelse(command!="holdup",const(velocity.jump.y)*0.667,const(velocity.jump.y))
[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0

[State 0, Mapset]
type = MapSet
trigger1 = Time = 0
map = "air_jump_used"
value = 1
ignorehitpause = 1

[State 45, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44

[State 45, 2]
type = ChangeAnim
trigger1 = !SelfAnimExist(44)
value = 41

[State 45, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
y = ifelse(command!="holdup",const(velocity.airjump.y)*0.667,const(velocity.airjump.y))
[State 45, 6]
type = Veladd
trigger1 = Time = 2
trigger1 = sysvar(1) = 1 && prevstateno = 110
x = const(velocity.airjump.fwd.x)*.5
[State 45, 6]
type = Velset
trigger1 = Time = 2
trigger1 = sysvar(1) = -1 && prevstateno = 110
x = const(velocity.airjump.back.x)
[State 45, 6]
type = Velset
trigger1 = Time = 2
trigger1 = sysvar(1) = 1 && prevstateno = 115
x = const(velocity.airjump.fwd.x)
[State 0, PlaySnd]
type = PlaySnd
trigger1 = Time = 2
value = S40,1
volume = 0
channel = -1
[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; SuperJump Start
[Statedef 9000]
type    = S
physics = S
anim = 9000
ctrl = 0
sprpriority = 1
facep2 = 1

[State 0, VelSet]
type = Velmul
trigger1 = prevstateno=410
x =.5

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0
;ignorehitpause = 
;persistent = 

[State 3400,AfterImage]
type = AfterImage
trigger1 = !time
time = 20
TimeGap  = 1
FrameGap = 4
length = 15
PalBright   = 0,0,0
PalContrast = 255,255,255
PalMul      = .8,.8,.8

[State 0, EnvShake]
type = EnvShake
trigger1 = AnimTime = 0
time = 5
freq = 60
ampl = -5
phase = 90
;ignorehitpause = 
;persistent = 

[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimTime = 0
value = f41,0
freqmul = 1
volumescale = 200
freqmul = 0.9+(random/5333.3)


[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 0, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = 1
text = "%f %f %f"
params = fvar(20),-enemynear,vel y/20

[State 40, YVelset]
type = VelSet
trigger1 = AnimTime = 0
y = ifelse(enemynear,vel y = 0,	-25,ifelse(enemynear,vel y < 0,	-25+enemynear,vel y/4,	 ifelse(-25+enemynear,vel y>-15,-15,-25+enemynear,vel y)))



[State 40, Jump Nowhere]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=0
x = const(velocity.jump.neu.x)

[State 40, Jump Back]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=-1
x = -15

[State 40, Jump Forward]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=1
x = ifelse(	(p2bodydist x/200*10)>20,	20,	10*ifelse(p2bodydist x/200<1,1,p2bodydist x/200))


[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1





;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 1]
type = ChangeState
trigger1 = command = "SuperJump2" && prevstateno=40&&time<5
value = 9000
ctrl = 0


[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > Const720p(-8)
trigger1 = SelfAnimExist(anim + 3)
trigger1 = anim >= 41 && anim <= 43
persistent = 0
value = Anim + 3


[State 0, PlayerPush]
type = PlayerPush
trigger1 = prevstateno=9000 && time < 10
value = 0
;ignorehitpause = 
;persistent = 

[State 0, VelAdd]
type = Velset
trigger1 = command = "holdfwd" && prevstateno=9000 && time < 5
x = ifelse((p2bodydist x/220*10)>20,20,10*ifelse(p2bodydist x/220<1,1,p2bodydist x/220))
[State 0, VelAdd]
type = Velset
trigger1 = command = "holdback" && prevstateno=9000 && time < 5
x = -10



[State 0, VelAdd]
type = Velset
trigger1 = command = "holdfwd" && prevstateno=45 && time < 5
x =const(velocity.airjump.fwd.x)
[State 0, VelAdd]
type = Velset
trigger1 = command = "holdback" && prevstateno=45 && time < 5
x = const(velocity.airjump.back.x)



[State 0, VelAdd]
type = VelAdd
trigger1 = command = "holdfwd" && vel x < const(velocity.runjump.fwd.x)*ifelse(prevstateno=9000,1,.5)
x = ifelse(vel x < -10,5,1)
[State 0, VelAdd]
type = VelAdd
trigger1 = command = "holdback" && vel x > const(velocity.runjump.back.x)*ifelse(prevstateno=9000,1,.5)
x = ifelse(vel x > 10,-5,-1)



[State 0, DopplerCalculator]
type = Helper
trigger1 = !numhelper(100000)
helpertype = Normal 
name = "DopplerCalculator"
ID = 100000
stateno = 100000
pos = 0,30
postype = p1    ;P2, Front, Back, Left, Right
keyctrl = 0
persistent = 0


;TimeShit
[Statedef 400]
movetype = U      ; AIHU
physics = N       ; SCANU          ;refers to the .Air file
sprpriority = 99    ; Stand behind everything 
ignorehitpause = 1
anim = f9999 

[State 0, DestroySelf]
type = changestate
trigger1 = root,movetype=H
value=401
ignorehitpause=1
[Statedef 401]
movetype = U      ; AIHU
physics = N       ; SCANU          ;refers to the .Air file
sprpriority = 99    ; Stand behind everything 
ignorehitpause = 1
anim = f9999
[State 0, DestroySelf]
type = changestate
trigger1 = root,movetype!=H
value=400
ignorehitpause=1
;----------------------------------------------
[Statedef -3]

[State 0, Mapset]
type = MapSet
trigger1 = 1
map = "floorbounceVelY"
value = (-20+pos y/40)*fvar(20)
ignorehitpause = 1
[State 0, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = 1
text = "%d  %f"
params = (p2bodydist x + p2bodydist y)/50,1+helper(100000),fvar(2)
;ignorehitpause = 
;persistent = 

[State 0, ScreenBound]
type = ScreenBound
trigger1 = enemynear,stateno = [5800,5820]
value = 1
movecamera = 0,1


[State 0, TimeStuff]
type = Helper
trigger1 = roundstate=2
trigger1 = !numhelper(400)
helpertype = Normal 
name = "TimeStuff"
ID = 400
stateno = 400
pos = 0,-140




[State -3, TurnInAir]
type = Turn
trigger1 = p2dist x < -5 && statetype = A && ctrl
[State -3, High Speed Width]
type = width
trigger1 = stateno !=650 && vel x > 0
player = (vel x)*.3, ifelse(vel x<0,0,(vel x))
ignorehitpause = 1

[State 0, Jump After Smear]
type = VelSet
trigger1 = stateno = 45 && prevstateno = 1010 && numtarget 
y = -15 
redirectID = target,id
[State 0, JumpOutofMovehit]
type = ChangeState
triggerall = !map(air_jump_used)
triggerall = hitpausetime=0
triggerall = command = "up"||command = "holdup"
trigger1 = statetype = A && movetype = A && movehit
trigger1 = stateno !=250 && stateno !=650
value = 45
[State 0, AirJumpReset]
type = MapSet
trigger1 = statetype !=A
map = "air_jump_used"
value = 0
ignorehitpause = 1


[State 0, VelAdd]
type = VelAdd
trigger1 = statetype = A && movetype = A && movehit
trigger1 = command = "holdfwd" && vel x < const(velocity.runjump.fwd.x)*.5
x = 2
[State 0, VelAdd]
type = VelAdd
trigger1 = statetype = A && movetype = A && movehit
trigger1 = command = "holdback" && vel x > const(velocity.runjump.back.x)*.5
x = -2

[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 42, 0

;Velocity Deterioration system (Edited from RicePigeon's Damage Proration system)
[State -2, Reset velocity dampener]
type = Varset
trigger1 = numenemy
trigger1 = (enemynear,statetype!=A)
trigger1 = (enemynear,movetype!=H)
trigger2 = !numenemy
fvar(20) = 1.0
[State 0, Make sure it never goes under the limit]
type = VarSet
trigger1 = fvar(20) < 0.25
fv = 20 
value = 0.25
ignorehitpause = 1
