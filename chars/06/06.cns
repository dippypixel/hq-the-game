[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1


[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
y = (const(velocity.jump.y))*ifelse(enemynear,vel y>6,ifelse((enemynear,vel y*5/40)<1.2,1.2,(enemynear,vel y*5/40)),2.2)
[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=0
x = const(velocity.jump.neu.x)
[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=-1
x = -15
[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = sysvar(1)=1
x = ifelse((p2bodydist x/220*10)>20,20,10*ifelse(p2bodydist x/220<1,1,p2bodydist x/220))


[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimTime = 0
trigger1 = vel x > 17
value = S40,2
volume = 0
channel = 0
freqmul = 0.9+(random/4000)
[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1





;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > Const720p(-8)
trigger1 = SelfAnimExist(anim + 3)
trigger1 = anim >= 41 && anim <= 43
persistent = 0
value = Anim + 3

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -50
;ignorehitpause = 
;persistent = 

[State 0, VelAdd]
type = Velset
trigger1 = command = "holdfwd" && prevstateno=9000 && time < 5
x = ifelse((p2bodydist x/220*10)>20,20,10*ifelse(p2bodydist x/220<1,1,p2bodydist x/220))
[State 0, VelAdd]
type = Velset
trigger1 = command = "holdback" && prevstateno=9000 && time < 5
x = -10



[State 0, VelAdd]
type = Velset
trigger1 = command = "holdfwd" && prevstateno=45 && time < 5
x =const(velocity.airjump.fwd.x)
[State 0, VelAdd]
type = Velset
trigger1 = command = "holdback" && prevstateno=45 && time < 5
x = const(velocity.airjump.back.x)



[State 0, VelAdd]
type = VelAdd
trigger1 = command = "holdfwd" && vel x < const(velocity.runjump.fwd.x)*ifelse(prevstateno=9000,1,.5)
x = ifelse(vel x < -10,5,1)
[State 0, VelAdd]
type = VelAdd
trigger1 = command = "holdback" && vel x > const(velocity.runjump.back.x)*ifelse(prevstateno=9000,1,.5)
x = ifelse(vel x > 10,-5,-1)



[Statedef -3]

[State 0, ChangeState]
type = ChangeState
trigger1 = statetype = A && movetype = A && movehit
trigger1 = command = "holdup" 
value = 45
[State 0, VelAdd]
type = VelAdd
trigger1 = statetype = A && movetype = A && movehit
trigger1 = command = "holdfwd" && vel x < const(velocity.runjump.fwd.x)*.5
x = 2
[State 0, VelAdd]
type = VelAdd
trigger1 = statetype = A && movetype = A && movehit
trigger1 = command = "holdback" && vel x > const(velocity.runjump.back.x)*.5
x = -2


[State 0, Mapset]
type = MapSet
trigger1 = !numtarget
map = "movement_ability_used"
value = 0
ignorehitpause = 1
[State 0, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = 1
text = "var(10) = %f %f %f"
params = gameheight,abs(30/vel x*4)
;ignorehitpause = 
;persistent = 
;ignorehitpause = 
;persistent = 
[State -3, stagrevear]
type = null;ModifyStageVar
trigger1 = enemy,stateno = 5800 && enemy,time = 1
camera.zoomout = camerazoom
ignorehitpause =1
[State -3, stagrevear]
type = null;ModifyStageVar
trigger1 = enemy,stateno = 5820 && stagevar(camera.zoomout)
camera.zoomout= .1
ignorehitpause =1
;This controller plays a sound everytime KFM lands from a jump, or
;from his back-dash.

[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 42, 0
