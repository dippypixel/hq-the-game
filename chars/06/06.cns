;Uppercut
[Statedef 250]
type    = S
movetype= A
physics = S
juggle  = 6
poweradd= 25
ctrl = 0
anim = 410
sprpriority = 2
[State 0, VelMul]
type = VelMul
trigger1 = vel x >35 && movehit
x = .7
ignorehitpause=0
[State 410, 1]
type = PlaySnd
trigger1 = Time = 1
value = 0, 2
;This is the second hit, triggered on the 4th element of animation.
[State 410, 3]
type = HitDef
trigger1 = AnimElem = 3
attr = C, NA
damage    = 75*fvar(20)
animtype  = Light
hitflag = MAF
guardflag = MA
pausetime = 12,12
sparkno = 1
sparkxy = -10,-70
guardsound = 6,0
ground.type = High
ground.slidetime = 14
ground.hittime  = 17
ground.velocity = ifelse(-vel x*.3>-8,-8,-vel x*.3),-25
air.velocity = ifelse(-vel x*.3>-8,-8,-vel x*.3),-25*fvar(20)
fall = 1
envshake.time = 12
envshake.freq = 90
envshake.ampl = -6
envshake.phase = 90
yaccel = .7/fvar(20)
[State 0, HitSnd]
type = PlaySnd
trigger1 = movehit
value = f5,4
volumescale = 100
channel = -1
ignorehitpause = 1
persistent=0
