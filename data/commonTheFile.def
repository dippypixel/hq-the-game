; Definition file for player
; Contains all the filenames needed for the character

; Player information
[Info]
name = ""        ;Name of character
displayname = "" ;Name of character to display
versiondate = 09,30,2009    ;Version date of character (MM-DD-YYYY or X.XX)
mugenversion = 1.0          ;Version of M.U.G.E.N character works on (X.XX)
author = ""      ;Character author name
pal.defaults =   ;Default palettes in order of preference

; Files for the player
[Files]
cmd     = common.cmd   ;Command set
cns     = common.const   ;Constants
st      = common2.cns   ;States
stcommon = common2.cns ;Common states
sprite  = fightfx.sff   ;Sprite
anim    = fightfx.air   ;Animation
sound  = common.snd   ;Sound