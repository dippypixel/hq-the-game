####################################################
[statedef +1] 
#-> helper spawn on teamleader
ignoreHitPause if roundstate != 0 && teamside = 1 && playerno = teamLeader && 
    ((const(arcade)              = 1   && gamemode = "arcade") ||  
    (const(bonus)               = 1   && gamemode = "bonus")  ||  
    (const(bossrush)            = 1   && gamemode = "bossrush") ||  
    (const(demo)                = 1   && gamemode = "demo") ||  
    (const(freebattle)          = 1   && gamemode = "freebattle") ||  
    (const(netplaysurvivalcoop) = 1   && gamemode = "netplaysurvivalcoop") || 
    (const(netplayteamcoop)     = 1   && gamemode = "netplayteamcoop") ||  
    (const(netplayversus)       = 1   && gamemode = "netplayversus") ||  
    (const(randomtest)          = 1   && gamemode = "randomtest") ||  
    (const(survival)            = 1   && gamemode = "survival") ||  
    (const(survivalcoop)        = 1   && gamemode = "survivalcoop") ||  
    (const(teamcoop)            = 1   && gamemode = "teamcoop") ||  
    (const(timeattack)          = 1   && gamemode = "timeattack") ||  
    (const(training)            = 1   && gamemode = "training") ||  
    (const(versus)              = 1   && gamemode = "versus") ||  
    (const(versuscoop)          = 1   && gamemode = "versuscoop"))  {  
ignoreHitPause if !numhelper(45991100) && alive && map(stickoff) = 0 && aILevel = 0{
helper{helpertype: normal; name:"stick"; stateno:45991100; id:45991100;	postype: p1; pos: -1000, -1000; superMoveTime:999; pauseMoveTime:999; }
}

#-----------------------------------------

#-> turn off
ignoreHitPause if roundstate != 0 && teamside = 1 && playerno = teamLeader && (InputTime(s) > 0) && 
(InputTime(w) > 0 || InputTime(d) > 0  ) && 
map(stickonofftoggle) = 0 {
map(stickonofftoggle):=15;
teammapset{map:"stickoff"; value:Cond(map(stickoff) < 1,1,0)} ##on/off
}




#-> reset map cooldown
ignorehitpause if map(commandx) > 0 {mapadd{map:"commandx";value:-1}}	
ignorehitpause if map(commandy) > 0 {mapadd{map:"commandy";value:-1}}	
ignorehitpause if map(commandz) > 0 {mapadd{map:"commandz";value:-1}}	
ignorehitpause if map(commanda) > 0 {mapadd{map:"commanda";value:-1}}	
ignorehitpause if map(commandb) > 0 {mapadd{map:"commandb";value:-1}}	
ignorehitpause if map(commandc) > 0 {mapadd{map:"commandc";value:-1}}	
ignorehitpause if map(commandShiftBack) > 0 {mapadd{map:"commandShiftBack";value:-1}}	
ignorehitpause if map(commandShiftFwd) > 0 {mapadd{map:"commandShiftFwd";value:-1}}	
ignorehitpause if map(commandstart) > 0 {mapadd{map:"commandstart";value:-1}}	
ignorehitpause if map(stickonofftoggle) > 0 {mapadd{map:"stickonofftoggle";value:-1}}	
	}
	
	
	##############################p2##############################
#-> helper spawn on teamleader
ignoreHitPause if roundstate != 0 && teamside = 2 && playerno = teamLeader &&  
    ((const(arcadep2)              = 1   && gamemode = "arcade") ||  
    (const(bonusp2)               = 1   && gamemode = "bonus")  ||  
    (const(bossrushp2)            = 1   && gamemode = "bossrush") ||  
    (const(demop2)                = 1   && gamemode = "demo") ||  
    (const(freebattlep2)          = 1   && gamemode = "freebattle") ||  
    (const(netplaysurvivalcoopp2) = 1   && gamemode = "netplaysurvivalcoop") || 
    (const(netplayteamcoopp2)     = 1   && gamemode = "netplayteamcoop") ||  
    (const(netplayversusp2)       = 1   && gamemode = "netplayversus") ||  
    (const(randomtestp2)          = 1   && gamemode = "randomtest") ||  
    (const(survivalp2)            = 1   && gamemode = "survival") ||  
    (const(survivalcoopp2)        = 1   && gamemode = "survivalcoop") ||  
    (const(teamcoopp2)            = 1   && gamemode = "teamcoop") ||  
    (const(timeattackp2)          = 1   && gamemode = "timeattack") ||  
    (const(trainingp2)            = 1   && gamemode = "training") ||  
    (const(versusp2)              = 1   && gamemode = "versus") ||  
    (const(versuscoopp2)          = 1   && gamemode = "versuscoop")) {  
ignoreHitPause if !numhelper(45991102) && alive && map(stickoff) = 0 && aILevel = 0{
helper{helpertype: normal; name:"stickp2"; stateno:45991102; id:45991102;	postype: p1; pos: -1000, -1000; superMoveTime:999; pauseMoveTime:999; }
}
#-> turn off
ignoreHitPause if roundstate != 0 && teamside = 2 && playerno = teamLeader && (InputTime(s) > 0) && 
(InputTime(w) > 0 || InputTime(d) > 0 ) && 
map(stickonofftoggle) = 0 {
map(stickonofftoggle):=15;
teammapset{map:"stickoff"; value:Cond(map(stickoff) < 1,1,0)} ##on/off
}




#-> reset map cooldown
ignorehitpause if map(commandx) > 0 {mapadd{map:"commandx";value:-1}}	
ignorehitpause if map(commandy) > 0 {mapadd{map:"commandy";value:-1}}	
ignorehitpause if map(commandz) > 0 {mapadd{map:"commandz";value:-1}}	
ignorehitpause if map(commanda) > 0 {mapadd{map:"commanda";value:-1}}	
ignorehitpause if map(commandb) > 0 {mapadd{map:"commandb";value:-1}}	
ignorehitpause if map(commandc) > 0 {mapadd{map:"commandc";value:-1}}	
ignorehitpause if map(commandShiftBack) > 0 {mapadd{map:"commandShiftBack";value:-1}}	
ignorehitpause if map(commandShiftFwd) > 0 {mapadd{map:"commandShiftFwd";value:-1}}	
ignorehitpause if map(commandstart) > 0 {mapadd{map:"commandstart";value:-1}}	
ignorehitpause if map(stickonofftoggle) > 0 {mapadd{map:"stickonofftoggle";value:-1}}	
	}