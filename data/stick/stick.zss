		 Cond(root,map(commandmap)=0 ,35,#reset

		   
		 35))))))))) * Cond(root,const(stylejp2)=0,1,10); postype: right; space: screen; pos: (-111+ (const(stickxoffsetp2)+const(stickjoyxoffsetp2)))*root,map(localcordx), (((166*root,map(xy))- const(stickyoffsetp2))-const(stickjoyyoffsetp2))-  Cond(root,const(stylejp2)=0,0,3); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0; } 
