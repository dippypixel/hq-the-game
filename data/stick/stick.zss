 [Statedef 45991100; type: S; movetype: I; physics: N;
 anim: ARSTK 999; sprpriority: -4; ctrl: 0; poweradd:0; juggle:0; ]

notHitBy{value: SCA; time: -1}
#-> setting maps
ignoreHitPause if roundstate != 0 {
if root,map(xy) = 0{root,map(xy):= (screenheight/180);}
if root,localCoord x !=0{root,map(localcordx) := (root,localCoord x/320);}
if root,localCoord x !=0{root,map(localcordxs) := (screenwidth/screenheight) < 1.77;}
if root,map(buttondelay) <1 {root,map(buttondelay):=root,const(buttondelay);}
if root,InputTime(B) > 0 {root,map(commandmap):= 1;}
if root,InputTime(F) > 0 {root,map(commandmap):= 2;}
if root,InputTime(U) > 0 {root,map(commandmap):= 3;}
if root,InputTime(D) > 0 {root,map(commandmap):= 4;}
if root,InputTime(B) > 0 && root,InputTime(U) > 0 {root,map(commandmap):= 10;}
if root,InputTime(F) > 0 && root,InputTime(U) > 0 {root,map(commandmap):= 11;}
if root,InputTime(B) > 0 && root,InputTime(D) > 0 {root,map(commandmap):= 20;}
if root,InputTime(F) > 0 && root,InputTime(D) > 0 {root,map(commandmap):= 21;}
if root,InputTime(F) < 0 && root,InputTime(B) < 0 && root,InputTime(U) < 0 && root,InputTime(D) < 0{root,map(commandmap):= 0;}
if root,InputTime(x) > 0 {root,map(commandx):= root,map(buttondelay);}
if root,InputTime(y) > 0 {root,map(commandy):= root,map(buttondelay);}
if root,InputTime(z) > 0 {root,map(commandz):= root,map(buttondelay);}
if root,InputTime(a) > 0 {root,map(commanda):= root,map(buttondelay);}
if root,InputTime(b) > 0 {root,map(commandb):= root,map(buttondelay);}
if root,InputTime(c) > 0 {root,map(commandc):= root,map(buttondelay);}
if root,InputTime(d) > 0 {root,map(commandShiftBack):= root,map(buttondelay);}
if root,InputTime(w) > 0 {root,map(commandShiftFwd):= root,map(buttondelay);}
if root,InputTime(s) > 0 {root,map(commandstart):= root,map(buttondelay);}


#-> stick
	ignoreHitPause if numExplod(888770) <2{
	removeexplod{id:888770;}
	if const(underlay) = 1 && ((root,const(stylej) = 0  && root,const(styleu) = 0) || (root,const(stylej) = 1  && root,const(styleu) = 1))  { explod{id:8887760; anim:ARSTK (100 * Cond(root,const(styleu)=0,1,10)) + root,const(plainunderlay)  ; postype: left; space: screen; pos: (20+ (const(stickxoffset)+const(stickjoyxoffset)))*root,map(localcordx), (((166*root,map(xy))- const(stickyoffset))-const(stickjoyyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1.33,1.33;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0; } }
	if const(underlay) = 1 && ((root,const(stylej) = 1  && root,const(styleu) = 0) || (root,const(stylej) = 0  && root,const(styleu) = 1))  { explod{id:8887760; anim:ARSTK (200 * Cond(root,const(styleu)=0,1,10)) + root,const(plainunderlay)  ; postype: left; space: screen; pos: (20+ (const(stickxoffset)+const(stickjoyxoffset)))*root,map(localcordx), (((166*root,map(xy))- const(stickyoffset))-const(stickjoyyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1.33,1.33;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0; } }
	

	explod{id:888770; anim:ARSTK 
		 Cond(root,map(commandmap)=1,Cond(root,facing=1,33,34), ##back
		 Cond(root,map(commandmap)=2 ,Cond(root,facing=1,34,33), #forward
		 Cond(root,map(commandmap)=3 ,38,#up
		 Cond(root,map(commandmap)=4 ,32,#down
		 Cond(root,map(commandmap)=10 ,Cond(root,facing=1,36,37),#up bk
		 Cond(root,map(commandmap)=11 ,Cond(root,facing=1,37,36),#up frwd
		 Cond(root,map(commandmap)=20 ,Cond(root,facing=1,30,31),#down bk
		 Cond(root,map(commandmap)=21 ,Cond(root,facing=1,31,30),#down frwd
		 Cond(root,map(commandmap)=0 ,35,#reset

		   
		 35))))))))) * Cond(root,const(stylej)=0,1,10) ; postype: left; space: screen; pos: (20+ (const(stickxoffset)+const(stickjoyxoffset)))*root,map(localcordx), (((166*root,map(xy))- const(stickyoffset))-const(stickjoyyoffset))-  Cond(root,const(stylej)=0,0,3); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0; } 
	}
	


#-> buttons
#-> x
	ignoreHitPause if numExplod(888870) <2 && const(showx) = 1{
	explod{id:888870; anim:ARSTK 
		 Cond(root,map(commandx)>0,const(cnx), 
		   
		 const(cnxd))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (50 + const(stickxoffset))*root,map(localcordx), ((162*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0;} 
	}

#-> y
	ignoreHitPause if numExplod(888871) <2 && const(showy) = 1{
	explod{id:888871; anim:ARSTK 
		 Cond(root,map(commandy)>0,const(cny), 
		   
		 const(cnyd))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (66+(cond(root,map(localcordxs) = 1,5,0)+ const(stickxoffset)))*root,map(localcordx), ((162*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0;} 
	}

#-> z
	ignoreHitPause if numExplod(888872) <2 && const(showz) = 1{
	explod{id:888872; anim:ARSTK 
		 Cond(root,map(commandz)>0,const(cnz), 
		   
		 const(cnzd))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (82+(cond(root,map(localcordxs) = 1,10,0)+ const(stickxoffset)))*root,map(localcordx), ((162*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0;} 
	}
	
#-> commandShiftBack
	ignoreHitPause if numExplod(888873) <2 && const(showtagsb) = 1{
	explod{id:888873; anim:ARSTK 
		 Cond(root,map(commandShiftBack)>0,const(cntsbd), 
		   
		 const(cntsbdd))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (98+(cond(root,map(localcordxs) = 1,15,0)+ const(stickxoffset)))*root,map(localcordx), ((162*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0} 
	}


#-> a
	ignoreHitPause if numExplod(888874) <2 && const(showa) = 1{
	explod{id:888874; anim:ARSTK 
		 Cond(root,map(commanda)>0,const(cna), 
		   
		 const(cnad))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (50+ const(stickxoffset))*root,map(localcordx), ((170*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0;} 
	}

#-> b
	ignoreHitPause if numExplod(888875) <2 && const(showb) = 1{
	explod{id:888875; anim:ARSTK 
		 Cond(root,map(commandb)>0,const(cnb), 
		   
		 const(cnbd))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (66+(cond(root,map(localcordxs) = 1,5,0)+ const(stickxoffset)))*root,map(localcordx), ((170*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0;} 
	}

#-> c
	ignoreHitPause if numExplod(888876) <2 && const(showc) = 1{
	explod{id:888876; anim:ARSTK 
		 Cond(root,map(commandc)>0,const(cnc), 
		   
		 const(cncd))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (82+(cond(root,map(localcordxs) = 1,10,0)+ const(stickxoffset)))*root,map(localcordx), ((170*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0;} 
	}
	
#-> commandShiftFwd
	ignoreHitPause if numExplod(888877) <2 && const(showtagsf) = 1{
	explod{id:888877; anim:ARSTK 
		 Cond(root,map(commandShiftFwd)>0,const(cntsfw), 
		   
		 const(cntsfwd))* Cond(root,const(style)=0,1,10); postype: left; space: screen; pos: (98+(cond(root,map(localcordxs) = 1,15,0)+ const(stickxoffset)))*root,map(localcordx), ((170*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0;} 
	}
	

	
#-> commandstart
	ignoreHitPause if numExplod(888878) <2 && const(showstart) = 1{
	explod{id:888878; anim:ARSTK 
		 Cond(root,map(commandstart)>0,const(cnst), const(cnstd))* Cond(root,const(style)=0,1,10);
		   
		  postype: left; space: screen; pos: (114+(cond(root,map(localcordxs) = 1,20,0)+ const(stickxoffset)))*root,map(localcordx), ((166*root,map(xy))- const(stickyoffset)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1,1;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0} 
	}
	

}

		
if root,playerno != teamLeader || root,map(stickoff) =1 || root,aILevel >0{
   removeexplod{}
   destroySelf{}
}
 
