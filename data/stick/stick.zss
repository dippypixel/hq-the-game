	if const(underlayp2) = 1 && ((const(styleup2) = 1 && const(stylejp2) = 0)|| (const(styleup2) = 0 && const(stylejp2) = 1)){ explod{id:8887760; anim:ARSTK (200 * Cond(root,const(styleup2)=0,1,10)) + root,const(plainunderlayp2)  ; postype: right; space: screen; pos: (-111+ (const(stickxoffsetp2)+const(stickjoyxoffsetp2)))*root,map(localcordx), (((166*root,map(xy))- const(stickyoffsetp2))-const(stickjoyyoffsetp2)); velocity: 0, 0; accel: 0, 0; removetime: 1;scale:1.33,1.33;under:0;ontop:1; superMoveTime: 0; pauseMoveTime: 0; } }
	
